Algoritmo ContadorMonedas
	// Definir las variables para la cantidad de cada moneda
	Definir m2e, m1e, m50c, m20c, m10c Como Entero
	Definir total_centimos, euros_final, centimos_final Como Entero
	
	// Entrada de datos
	Escribir "Cantidad de monedas de 2 euros:"
	Leer m2e
	Escribir "Cantidad de monedas de 1 euro:"
	Leer m1e
	Escribir "Cantidad de monedas de 50 céntimos:"
	Leer m50c
	Escribir "Cantidad de monedas de 20 céntimos:"
	Leer m20c
	Escribir "Cantidad de monedas de 10 céntimos:"
	Leer m10c
	
	// Proceso
	// 2 euros = 200 céntimos | 1 euro = 100 céntimos
	total_centimos <- (m2e * 200) + (m1e * 100) + (m50c * 50) + (m20c * 20) + (m10c * 10)
	
	// eruros y centimos separados
	euros_final <- trunc(total_centimos / 100)
	centimos_final <- total_centimos MOD 100
	
	// Salida de resultados
	Escribir "Tienes un total de: ", euros_final, " euros y ", centimos_final, " céntimos."
	
FinAlgoritmo
